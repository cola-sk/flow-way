# 腾讯地图 WebService Key
# 申请地址：https://lbs.qq.com/dev/center/application/new
# 应用类型选 "Web服务"，并在 Key 设置中配置域名白名单
TENCENT_MAP_KEY=your_tencent_map_key_here

# Upstash Redis（通过 Vercel Marketplace 绑定后自动注入）
# https://vercel.com/dashboard → Storage → Upstash for Redis
KV_REST_API_URL=your_upstash_rest_url
KV_REST_API_TOKEN=your_upstash_rest_token
